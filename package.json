{
	"name": "team2-frontend",
	"version": "1.0.0",
	"description": "Team2 Frontend",
	"main": "dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc && node -e \"const fs=require('fs');fs.cpSync('src/views','dist/views',{recursive:true});fs.cpSync('src/public','dist/public',{recursive:true});\"",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"dependencies": {
		"axios": "^1.18.1",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.4.2",
		"express": "^4.21.2",
		"nunjucks": "^3.2.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^4.17.23",
		"@types/node": "^26.1.0",
		"@types/nunjucks": "^3.2.6",
		"@types/supertest": "^7.2.0",
		"@vitest/coverage-v8": "^4.1.10",
		"supertest": "^7.2.2",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	}
}
