{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"types": ["node", "vitest/globals", "cookie-parser"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
