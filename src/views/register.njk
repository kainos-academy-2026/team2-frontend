{% extends "_form-layout.njk" %}

{% block title %}Create Account{% endblock %}
{% block ariaLabel %}Registration page{% endblock %}

{% block brandBlurb %}
  <p>Join thousands of professionals finding their next opportunity.</p>
  <p>Create your account to get started.</p>
{% endblock %}

{% block brandIcon %}
  <div>
    <img
      class="brand-icon"
      src="/public/icons/Register_Icon.png"
      alt=""
      aria-hidden="true"
    />
  </div>
{% endblock %}

{% block eyebrow %}Create account{% endblock %}
{% block heading %}Register{% endblock %}
{% block intro %}Enter your details below to create an account.{% endblock %}

{% block alerts %}
  {% if error %}
    <div class="alert alert-error" role="alert">{{ error }}</div>
  {% endif %}
  {% if success %}
    <div class="alert alert-success" role="status">{{ success }}</div>
  {% endif %}
{% endblock %}

{% block formContent %}
  {% from '_field-macro.njk' import field %}
  <form method="post" action="/register">
    {{ field('fullName', 'Full name', 'text', 'Jane Smith', values.fullName, fieldErrors, 'name') }}
    {{ field('email', 'Email address', 'email', 'jane.smith@example.com', values.email, fieldErrors, 'email') }}
    {{ field('password', 'Password', 'password', 'Create a secure password', values.password, fieldErrors, 'new-password') }}
    {{ field('confirmPassword', 'Confirm password', 'password', 'Re-enter your password', values.confirmPassword, fieldErrors, 'new-password') }}

    <div class="helper-row" aria-hidden="true">
      <span>Use at least 8 characters.</span>
    </div>

    <button class="btn-primary" type="submit">Register</button>
  </form>
{% endblock %}

{% block formFooter %}
  <p class="form-footer">
    Already have an account? <a href="/login">Sign in</a>.
  </p>
{% endblock %}
