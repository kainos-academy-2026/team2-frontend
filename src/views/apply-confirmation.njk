{% extends "_form-layout.njk" %}

{% block title %}Application Submitted{% endblock %}
{% block ariaLabel %}Application confirmation page{% endblock %}

{% block brandBlurb %}
  <p>Thank you for applying to Kainos.</p>
  <p>Your application has been received and is now being reviewed.</p>
{% endblock %}

{% block eyebrow %}Application submitted{% endblock %}
{% block heading %}Thank you{% endblock %}
{% block intro %}Your submission has been received successfully.{% endblock %}

{% block alerts %}
  {% if jobRole %}
    <div class="alert alert-success" role="status">
      Your application for <strong>{{ jobRole.name }}</strong> has been submitted.
    </div>
  {% else %}
    <div class="alert alert-success" role="status">
      Your application has been submitted.
    </div>
  {% endif %}
{% endblock %}

{% block formFooter %}
  <p class="form-footer">
    <a href="/job-roles">Back to job roles</a>
  </p>
{% endblock %}
