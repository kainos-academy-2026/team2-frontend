<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Job Role Detail</title>
        <link rel="stylesheet" href="/styles.css" />
    </head>
    <body>
        <a href="/job-roles">Back to job roles</a>

        {% if jobRole %}
            <h1>{{ jobRole.name or "Job Role" }}</h1>
            <p class="meta">
                Status: {{ jobRole.status or "-" }} | Open positions: {{ jobRole.numberOfOpenPositions or 0 }}
            </p>
            <section class="card">
                <h2>Description</h2>
                <p>{{ jobRole.description or "No description available." }}</p>
            </section>
            <section class="card">
                <h2>Specification</h2>
                <p>{{ jobRole.specification or "No specification available." }}</p>
            </section>
            <section class="card">
                <h2>Responsibilities</h2>
                <p>{{ jobRole.responsibilities or "No responsibilities available." }}</p>
            </section>
            <section class="card">
                <h2>SharePoint</h2>
                {% if jobRole.sharepointUrl %}
                    <p><a href="{{ jobRole.sharepointUrl }}" target="_blank" rel="noopener noreferrer">Open role workspace</a></p>
                {% else %}
                    <p>No SharePoint URL available.</p>
                {% endif %}
            </section>
        {% else %}
            <h1>Role detail unavailable</h1>
            <p>{{ message or "Could not load this job role right now." }}</p>
        {% endif %}
    </body>
</html>
