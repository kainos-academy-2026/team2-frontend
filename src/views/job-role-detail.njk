{% extends "_layout.njk" %}

{% block title %}{% if jobRole %}{{ jobRole.name }}{% else %}Job Role Detail{% endif %}{% endblock %}

{% block nav %}
  <a href="/job-roles">All Roles</a>
  <form action="/logout" method="POST" style="margin: 0;">
    <button type="submit" class="nav-cta" style="cursor: pointer; font: inherit;">Log Out</button>
  </form>
{% endblock %}

{% block content %}
  <div style="max-width: 900px; margin: 2rem auto; padding: 0 2rem;">
    <a href="/job-roles" style="color: var(--brand-primary); font-weight: 600; text-decoration: none;">&#8592; Back to job roles</a>

    {% if jobRole %}
      <h1 style="margin: 1.5rem 0 0.5rem; color: var(--brand-secondary);">{{ jobRole.name or "Job Role" }}</h1>
      <p style="color: var(--text-muted); margin-bottom: 2rem;">
        Status: {{ jobRole.status or "-" }} | Open positions: {{ jobRole.numberOfOpenPositions or 0 }}
      </p>
      <section style="border: 1px solid var(--border-soft); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
        <h2 style="margin: 0 0 1rem; color: var(--brand-secondary);">Role information</h2>
        <p style="margin: 0.25rem 0;">Location: {{ jobRole.location or "-" }}</p>
        <p style="margin: 0.25rem 0;">Capability: {{ jobRole.capability or "-" }}</p>
        <p style="margin: 0.25rem 0;">Band: {{ jobRole.band or "-" }}</p>
        <p style="margin: 0.25rem 0;">Closing date: {{ jobRole.closingDate or "-" }}</p>
      </section>
      <section style="border: 1px solid var(--border-soft); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
        <h2 style="margin: 0 0 1rem; color: var(--brand-secondary);">Description</h2>
        <p style="margin: 0; color: var(--text-muted); line-height: 1.7;">{{ jobRole.description or "No description available." }}</p>
      </section>
      <section style="border: 1px solid var(--border-soft); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
        <h2 style="margin: 0 0 1rem; color: var(--brand-secondary);">Specification</h2>
        {% if jobRole.sharepointUrl %}
          <p style="margin: 0;"><a href="{{ jobRole.sharepointUrl }}" target="_blank" rel="noopener noreferrer" style="color: var(--brand-primary);">Open SharePoint</a></p>
            {% if user.isAdmin %}
                <form id="delete-role-detail-form" action="/job-roles/{{ jobRole.id }}/delete" method="POST" class="delete-role-form">
                    <button
                        type="button"
                        data-delete-open
                        data-form-id="delete-role-detail-form"
                        data-role-name="{{ jobRole.name or 'this role' }}"
                    >
                        Delete role
                    </button>
                </form>
            {% endif %}
            {% if canApply %}
                <a href="/job-roles/{{ jobRole.id }}/apply">Apply for this role</a>
            {% endif %}

            {% if user.isAdmin %}
                <dialog id="delete-role-modal" aria-labelledby="delete-role-title" aria-describedby="delete-role-description">
                    <h2 id="delete-role-title">Confirm role deletion</h2>
                    <p id="delete-role-description">
                        Are you sure you want to delete <strong id="delete-role-name">this role</strong>? This action cannot be undone.
                    </p>
                    <div class="dialog-actions">
                        <button type="button" id="delete-cancel-btn">Cancel</button>
                        <button type="button" id="delete-confirm-btn">Delete role</button>
                    </div>
                </dialog>
            {% endif %}
        {% else %}
          <p style="margin: 0; color: var(--text-muted);">No specification available.</p>
        {% endif %}
        <script src="/public/delete-role-modal.js"></script>
      </section>
      <section style="border: 1px solid var(--border-soft); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
        <h2 style="margin: 0 0 1rem; color: var(--brand-secondary);">Responsibilities</h2>
        <p style="margin: 0; color: var(--text-muted); line-height: 1.7;">{{ jobRole.responsibilities or "No responsibilities available." }}</p>
      </section>
    {% else %}
      <h1 style="margin: 2rem 0 0.5rem; color: var(--brand-secondary);">Role detail unavailable</h1>
      <p style="color: var(--text-muted);">{{ message or "Could not load this job role right now." }}</p>
    {% endif %}
  </div>
{% endblock %}
