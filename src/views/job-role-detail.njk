<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Job Role Detail</title>
        <style>
            body {
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                margin: 2rem;
            }

            .meta {
                color: #4b5563;
                margin-bottom: 1.5rem;
            }

            .card {
                border: 1px solid #d1d5db;
                border-radius: 0.5rem;
                padding: 1rem;
                max-width: 800px;
            }

            a {
                display: inline-block;
                margin-bottom: 1rem;
            }
        </style>
    </head>
    <body>
        <a href="/job-roles">Back to job roles</a>

        {% if jobRole %}
            <h1>{{ jobRole.name or "Job Role" }}</h1>
            <p class="meta">
                {{ jobRole.capability or "-" }} | Band {{ jobRole.band or "-" }} | {{ jobRole.location or "-" }}
            </p>
            <section class="card">
                <h2>Specification</h2>
                <p>{{ jobRole.specification or "No specification available." }}</p>
            </section>
        {% else %}
            <h1>Role detail unavailable</h1>
            <p>{{ message or "Could not load this job role right now." }}</p>
        {% endif %}
    </body>
</html>
