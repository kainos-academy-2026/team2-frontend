<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In</title>
    {% import '_field-macro.njk' as _field %}
    <style>
      :root {
        --page-background: #e8eef8;
        --panel-surface: rgba(10, 20, 60, 0.96);
        --card-surface: #ffffff;
        --brand-primary: #00a651;
        --brand-secondary: #0d1b3e;
        --brand-highlight: #7ee8b0;
        --text-primary: #0d1b3e;
        --text-muted: #4a5a7a;
        --border-soft: #c8d4e8;
        --shadow-soft: 0 26px 60px rgba(10, 20, 60, 0.22);
        --input-surface: #f4f7fc;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Aptos", "Segoe UI", sans-serif;
        color: var(--text-primary);
        background:
          radial-gradient(circle at top left, rgba(0, 166, 81, 0.18), transparent 40%),
          linear-gradient(135deg, #eaf0fb 0%, var(--page-background) 60%, #dce8f5 100%);
      }

      .page {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 32px 20px;
      }

      .shell {
        width: min(1100px, 100%);
        display: grid;
        grid-template-columns: minmax(280px, 0.95fr) minmax(320px, 1.05fr);
        border-radius: 28px;
        overflow: hidden;
        background: var(--card-surface);
        box-shadow: var(--shadow-soft);
      }

      .brand-panel {
        padding: 48px;
        background: linear-gradient(160deg, #0d1b3e 0%, #0a3d62 45%, #00a651 100%);
        color: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 32px;
      }

      .brand-lockup {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 0.82rem;
      }

      .brand-blurb {
        margin-top: 32px;
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .brand-blurb p {
        margin: 0;
        font-size: 1.25rem;
        line-height: 1.6;
        opacity: 0.9;
        color: #ffffff;
        font-weight: 500;
      }

      .brand-logo {
        display: block;
        width: 150px;
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 50%, black 55%, transparent 100%);
        mask-image: radial-gradient(ellipse 85% 85% at 50% 50%, black 55%, transparent 100%);
      }

      .brand-icon {
        display: block;
        width: 280px;
        max-width: 100%;
        height: auto;
        margin-top: 120px;
        border-radius: 16px;
        -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 50%, transparent 100%);
        mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 50%, transparent 100%);
      }

      .form-panel {
        padding: 48px;
        display: flex;
        align-items: center;
        background: linear-gradient(180deg, #ffffff 0%, #f9fcfb 100%);
      }

      .form-wrap {
        width: min(100%, 440px);
        margin: 0 auto;
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--brand-primary);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .form-wrap h2 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 2.6rem);
        line-height: 1.1;
      }

      .intro {
        margin: 14px 0 30px;
        color: var(--text-muted);
        line-height: 1.7;
      }

      form {
        display: grid;
        gap: 18px;
      }

      .field {
        display: grid;
        gap: 8px;
      }

      .field-errors {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .field-error {
        margin: 0 0 6px 0;
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.45;
        color: #d32f2f;
        display: block;
      }

      label {
        font-size: 0.95rem;
        font-weight: 700;
      }

      input {
        width: 100%;
        border: 1px solid var(--border-soft);
        border-radius: 16px;
        padding: 15px 16px;
        background: var(--input-surface);
        color: var(--text-primary);
        font: inherit;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
      }

      input::placeholder {
        color: #8a9a93;
      }

      input:focus {
        outline: none;
        border-color: var(--brand-primary);
        box-shadow: 0 0 0 4px rgba(0, 122, 83, 0.15);
        background: #ffffff;
      }

      input.input-error {
        border-color: #d32f2f;
        box-shadow: 
          0 0 0 4px rgba(211, 47, 47, 0.15),
          0 0 12px rgba(211, 47, 47, 0.3);
        background: #ffebee;
      }

      input.input-error:focus {
        border-color: #d32f2f;
        box-shadow: 
          0 0 0 4px rgba(211, 47, 47, 0.25),
          0 0 16px rgba(211, 47, 47, 0.4);
      }

      .signin-button {
        border: none;
        border-radius: 999px;
        padding: 16px 20px;
        background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
        color: #ffffff;
        font: inherit;
        font-weight: 700;
        letter-spacing: 0.01em;
        cursor: pointer;
        box-shadow: 0 20px 34px rgba(0, 122, 83, 0.22);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .signin-button:hover {
        transform: translateY(-1px);
        box-shadow: 0 24px 40px rgba(0, 122, 83, 0.28);
      }

      .form-footer {
        margin-top: 18px;
        color: var(--text-muted);
        font-size: 0.92rem;
        line-height: 1.6;
      }

      .form-footer a {
        color: var(--brand-primary);
        font-weight: 700;
        text-decoration: none;
      }

      .alert {
        margin-bottom: 18px;
        padding: 12px 14px;
        border-radius: 12px;
        font-size: 0.92rem;
        line-height: 1.5;
      }

      .alert-error {
        background: #fff1f0;
        border: 1px solid #ffd2cc;
        color: #7f1d1d;
      }

      .alert-loggedout {
        background: #ecfdf3;
        border: 1px solid #b7f0cb;
        color: #14532d;
      }

      @media (max-width: 860px) {
        .shell {
          grid-template-columns: 1fr;
        }

        .brand-panel,
        .form-panel {
          padding: 36px 28px;
        }
      }

      @media (max-width: 540px) {
        .page {
          padding: 16px;
        }

        .brand-panel,
        .form-panel {
          padding: 28px 22px;
        }
      }
    </style>
  </head>
  <body>
    <main class="page">
      <section class="shell" aria-label="Sign in page">
        <aside class="brand-panel" aria-label="Brand information">
          <div>
            <div class="brand-lockup">
              <img
                class="brand-logo"
                src="/public/icons/Kainos_Logo.png"
                alt="Kainos logo"
              />
            </div>

            <div class="brand-blurb">
              <p>Welcome back to your career journey.</p>
              <p>Sign in to your account to continue.</p>
            </div>

            <div>
              <img 
                class="brand-icon"
                src="/public/icons/LoginIcon.png"
                alt="Icon"
              />
            </div>
          </div>
        </aside>

        <section class="form-panel">
          <div class="form-wrap">
            <p class="eyebrow">Sign in</p>
            <h2>Welcome</h2>
            <p class="intro">
              Enter your credentials to access your account.
            </p>

            {% if loggedOut %}
              <div class="alert alert-loggedout" role="status">You have been logged out successfully.</div>
            {% endif %}

            {% if error %}
              <div class="alert alert-error" role="alert">{{ error }}</div>
            {% endif %}

            <form method="post" action="/login">
              {% if csrfToken %}
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
              {% endif %}

              {{ _field.field('email', 'Email address', 'email', 'jane.smith@example.com', oldInput.email, fieldErrors, 'username') }}
              {{ _field.field('password', 'Password', 'password', 'Enter your password', oldInput.password, fieldErrors, 'current-password') }}

              <button class="signin-button" type="submit">Sign In</button>
            </form>

            <p class="form-footer">
              Don't have an account? <a href="/register">Create one now</a>.
            </p>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
