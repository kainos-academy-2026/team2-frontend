{% extends "_form-layout.njk" %}

{% block title %}Sign In{% endblock %}
{% block ariaLabel %}Sign in page{% endblock %}

{% block brandBlurb %}
  <p>Welcome back to your career journey.</p>
  <p>Sign in to your account to continue.</p>
{% endblock %}

{% block brandIcon %}
  <div>
    <img
      class="brand-icon"
      src="/public/icons/LoginIcon.png"
      alt=""
      aria-hidden="true"
    />
  </div>
{% endblock %}

{% block eyebrow %}Sign in{% endblock %}
{% block heading %}Welcome{% endblock %}
{% block intro %}Enter your credentials to access your account.{% endblock %}

{% block alerts %}
  {% if loggedOut %}
    <div class="alert alert-loggedout" role="status">You have been logged out successfully.</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" role="alert">{{ error }}</div>
  {% endif %}
{% endblock %}

{% block formContent %}
  {% from '_field-macro.njk' import field %}
  <form action="/login" method="POST">
    {% if csrfToken %}
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    {% endif %}

    {{ field('email', 'Email address', 'email', 'jane.smith@example.com', oldInput.email, fieldErrors, 'username') }}
    {{ field('password', 'Password', 'password', 'Enter your password', oldInput.password, fieldErrors, 'current-password') }}

    <button class="btn-primary" type="submit">Sign In</button>
  </form>
{% endblock %}

{% block formFooter %}
  <p class="form-footer">
    Don't have an account? <a href="/register">Create one now</a>.
  </p>
{% endblock %}
