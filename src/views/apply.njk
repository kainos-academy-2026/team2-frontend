<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Apply for {{ jobRole.name if jobRole else "Job Role" }}</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <a href="/job-roles/{{ jobRole.id if jobRole }}">Back to job role</a>

    <h1>Apply for {{ jobRole.name if jobRole else "this role" }}</h1>

    {% if error %}
      <div class="alert alert-error" role="alert">{{ error }}</div>
    {% endif %}

    <form id="apply-form" method="post" action="/job-roles/{{ jobRole.id if jobRole }}/apply" novalidate>
      <div class="field">
        <label for="cv-file">Upload your CV (PDF only, max 5MB)</label>
        <div id="cv-file-error" class="field-error" role="alert" hidden></div>
        <input
          id="cv-file"
          name="cv-file"
          type="file"
          accept="application/pdf"
          aria-describedby="cv-file-error"
          required
        />
      </div>

      <input type="hidden" id="cvKey" name="cvKey" value="" />

      <div id="upload-status" hidden>
        <p>Uploading CV…</p>
      </div>

      <button type="submit" id="submit-btn">Submit application</button>
    </form>

    <script src="/public/apply.js"></script>
  </body>
</html>
