<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Job Role List</title>
        <style>
            body {
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                margin: 2rem;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                border: 1px solid #d1d5db;
            }

            th,
            td {
                border: 1px solid #d1d5db;
                padding: 0.75rem;
                text-align: left;
            }

            thead th {
                background-color: #f3f4f6;
            }
        </style>
    </head>
    <body>
        <h1>Job Role List</h1>
        <!-- Expected jobRoles item shape: { id, name, status, description, responsibilities, sharepointUrl, numberOfOpenPositions } -->
        {% set hasOpenRoles = false %}
        {% for jobRole in jobRoles %}
            {% if (jobRole.status or "") | upper == "OPEN" %}
                {% set hasOpenRoles = true %}
            {% endif %}
        {% endfor %}

        <table>
            <thead>
                <tr>
                    <th scope="col">Role Name</th>
                    <th scope="col">Status</th>
                    <th scope="col">Open Positions</th>
                    <th scope="col">Description</th>
                    <th scope="col">Responsibilities</th>
                    <th scope="col">SharePoint</th>
                </tr>
            </thead>
            <tbody>
                {% if hasOpenRoles %}
                    {% for jobRole in jobRoles %}
                        {% if (jobRole.status or "") | upper == "OPEN" %}
                            <tr>
                                <td>
                                    {% if jobRole.id %}
                                        <a href="/job-roles/{{ jobRole.id }}">{{ jobRole.name or "-" }}</a>
                                    {% else %}
                                        {{ jobRole.name or "-" }}
                                    {% endif %}
                                </td>
                                <td>OPEN</td>
                                <td>{{ jobRole.numberOfOpenPositions or 0 }}</td>
                                <td>{{ jobRole.description or "-" }}</td>
                                <td>{{ jobRole.responsibilities or "-" }}</td>
                                <td>
                                    {% if jobRole.sharepointUrl %}
                                        <a href="{{ jobRole.sharepointUrl }}" target="_blank" rel="noopener noreferrer">View</a>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="6">No open job roles are available right now.</td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </body>
</html>