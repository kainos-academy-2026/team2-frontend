{% extends "_layout.njk" %}

{% block title %}Job Role List{% endblock %}

{% block extraStyles %}
  <link rel="stylesheet" href="/public/job-role-list.css" />
{% endblock %}

{% block nav %}
  <form action="/logout" method="POST" style="margin: 0;">
    <button type="submit" class="nav-cta" style="cursor: pointer; font: inherit;">Log Out</button>
  </form>
{% endblock %}

{% block content %}
  <div class="page">
    <section class="shell" aria-labelledby="job-role-title">
      <header class="hero">
        <div class="hero-top">
          <p class="eyebrow">Kainos Careers</p>
          <img
            class="hero-logo"
            src="/public/icons/Kainos_Logo.png"
            alt="Kainos logo"
          />
        </div>
        <h1 id="job-role-title">Job Role List</h1>
        {% if deletedMessage %}
            <p class="success-banner" role="status">{{ deletedMessage }}</p>
        {% endif %}
        <p class="intro">Browse the current open roles and closing dates.</p>
      </header>

      {% if forbidden %}
        <p style="color: red; padding: 0 24px;">You do not have permission to access that page.</p>
      {% endif %}

      {% set hasOpenRoles = false %}
      {% for jobRole in jobRoles %}
        {% if (jobRole.status or "") | upper == "OPEN" %}
          {% set hasOpenRoles = true %}
        {% endif %}
      {% endfor %}

        <p>Welcome, {{ user.name }}!</p>
        <p>Your role: {{ user.role }}</p>
        {% if user.isAdmin %}
            <p>Admin: Yes</p>
        {% else %}
            <p>Admin: No</p>
        {% endif %}

      <div class="table-wrap" role="region" aria-label="Open job roles">
        <table>
            <thead>
                <tr>
                    <th scope="col">Role Name</th>
                    <th scope="col">Location</th>
                    <th scope="col">Capability</th>
                    <th scope="col">Band</th>
                    <th scope="col">Closing Date</th>
                    <th scope="col">Status</th>
                    {% if user.isAdmin %}
                        <th scope="col">Actions</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% if hasOpenRoles %}
                    {% for jobRole in jobRoles %}
                        {% if (jobRole.status or "") | upper == "OPEN" %}
                            <tr>
                                <td>
                                    {% if jobRole.id %}
                                        <a href="/job-roles/{{ jobRole.id }}">{{ jobRole.name or "-" }}</a>
                                    {% else %}
                                        {{ jobRole.name or "-" }}
                                    {% endif %}
                                </td>
                                <td>{{ jobRole.location or "-" }}</td>
                                <td>{{ jobRole.capability or "-" }}</td>
                                <td>{{ jobRole.band or "-" }}</td>
                                <td>{{ jobRole.closingDate or "-" }}</td>
                                {% if user.isAdmin %}
                                    <td>
                                        <form id="delete-role-{{ jobRole.id }}" action="/job-roles/{{ jobRole.id }}/delete" method="POST" class="delete-role-form">
                                            <button
                                                type="button"
                                                data-delete-open
                                                data-form-id="delete-role-{{ jobRole.id }}"
                                                data-role-name="{{ jobRole.name or 'this role' }}"
                                            >
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                {% endif %}
                            </tr>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="{{ 6 if user.isAdmin else 5 }}">No open job roles are available right now.</td>
                    </tr>
                {% endif %}
            </tbody>
        </table>

        {% if user.isAdmin %}
            <dialog id="delete-role-modal" aria-labelledby="delete-role-title" aria-describedby="delete-role-description">
                <h2 id="delete-role-title">Confirm role deletion</h2>
                <p id="delete-role-description">
                    Are you sure you want to delete <strong id="delete-role-name">this role</strong>? This action cannot be undone.
                </p>
                <div class="dialog-actions">
                    <button type="button" id="delete-cancel-btn">Cancel</button>
                    <button type="button" id="delete-confirm-btn">Delete role</button>
                </div>
            </dialog>
        {% endif %}
        <script src="/public/delete-role-modal.js"></script>
      </div>
    </section>
  </div>
{% endblock %}