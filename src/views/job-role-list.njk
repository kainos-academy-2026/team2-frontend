<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Job Role List</title>
        <link rel="stylesheet" href="/public/job-role-list.css" />
    </head>
    <body>
        <form action="/logout" method="POST" style="margin-bottom: 1rem;">
            <button type="submit">Log Out</button>
        </form>
        <h1>Job Role List</h1>
        <!-- Expected jobRoles item shape: { id, name, location, capability, band, closingDate, status } -->
        {% set hasOpenRoles = false %}
        {% for jobRole in jobRoles %}
            {% if (jobRole.status or "") | upper == "OPEN" %}
                {% set hasOpenRoles = true %}
            {% endif %}
        {% endfor %}

        <table>
            <thead>
                <tr>
                    <th scope="col">Role Name</th>
                    <th scope="col">Location</th>
                    <th scope="col">Capability</th>
                    <th scope="col">Band</th>
                    <th scope="col">Closing Date</th>
                </tr>
            </thead>
            <tbody>
                {% if hasOpenRoles %}
                    {% for jobRole in jobRoles %}
                        {% if (jobRole.status or "") | upper == "OPEN" %}
                            <tr>
                                <td>
                                    {% if jobRole.id %}
                                        <a href="/job-roles/{{ jobRole.id }}">{{ jobRole.name or "-" }}</a>
                                    {% else %}
                                        {{ jobRole.name or "-" }}
                                    {% endif %}
                                </td>
                                <td>{{ jobRole.location or "-" }}</td>
                                <td>{{ jobRole.capability or "-" }}</td>
                                <td>{{ jobRole.band or "-" }}</td>
                                <td>{{ jobRole.closingDate or "-" }}</td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="5">No open job roles are available right now.</td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </body>
</html>